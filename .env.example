# 复制为 .env 后填写（.env 已在 .gitignore，不会提交）

# LLM：火山方舟（默认）
LLM_PROVIDER=volcano
ARK_API_KEY=你的API_Key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# 在控制台「在线推理」→ 创建接入点 → 复制接入点 ID（ep- 开头）
ARK_MODEL=ep-xxxxxxxx-xxxxx

# 可选：切换其他 LLM
# LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=

# 本地 embedding 模型（部署到 Railway 建议用 BAAI/bge-small-zh）
EMBEDDING_MODEL_NAME=BAAI/bge-base-zh

# 启动时自动检测 curriculum/、knowledge/ 变更并入库（默认 true）
AUTO_INGEST_ON_STARTUP=true

# 部署：逗号分隔前端域名（Vercel 地址填这里）
# CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app
